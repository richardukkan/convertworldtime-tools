<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sports Match Time Converter</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/luxon/3.4.4/luxon.min.js"></script>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Segoe UI', Arial, sans-serif;
    background: #ddeef8;
    min-height: 100vh;
    padding: 30px 16px 60px;
    color: #1a2533;
  }

  h1 {
    text-align: center;
    font-size: 28px;
    font-weight: 700;
    color: #1a2533;
    margin-bottom: 6px;
  }

  .subtitle {
    text-align: center;
    font-size: 14px;
    color: #4a6a85;
    margin-bottom: 28px;
  }

  .card {
    background: #fff;
    border-radius: 12px;
    padding: 28px 28px 24px;
    max-width: 620px;
    margin: 0 auto 28px;
    box-shadow: 0 2px 12px rgba(30,90,150,0.07);
  }

  .field-label {
    font-size: 14px;
    font-weight: 600;
    color: #1a2533;
    margin-bottom: 8px;
    display: block;
  }

  .field-group {
    margin-bottom: 18px;
  }

  input[type="text"],
  input[type="date"],
  input[type="time"],
  select {
    width: 100%;
    padding: 13px 14px;
    border: 1.5px solid #c8dcea;
    border-radius: 8px;
    font-size: 15px;
    color: #1a2533;
    background: #f4f9fd;
    outline: none;
    transition: border-color 0.2s;
    appearance: auto;
  }

  input[type="text"]::placeholder { color: #90afc5; }

  input:focus, select:focus {
    border-color: #3b8fd4;
    background: #fff;
  }

  .row-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
  }

  .btn {
    width: 100%;
    padding: 14px;
    border: none;
    border-radius: 8px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.06em;
    cursor: pointer;
    text-transform: uppercase;
    transition: background 0.18s, transform 0.1s;
  }

  .btn-primary {
    background: #3b8fd4;
    color: #fff;
    margin-bottom: 12px;
  }
  .btn-primary:hover { background: #2d7abf; }
  .btn-primary:active { transform: scale(0.98); }

  .btn-secondary {
    background: #3b8fd4;
    color: #fff;
  }
  .btn-secondary:hover { background: #2d7abf; }

  .btn-remove {
    background: none;
    border: none;
    color: #90afc5;
    font-size: 20px;
    cursor: pointer;
    padding: 0 4px;
    line-height: 1;
    float: right;
    margin-top: -2px;
  }
  .btn-remove:hover { color: #e05555; }

  .city-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }
  .city-row input { margin-bottom: 0; flex: 1; }

  .section-title {
    font-size: 13px;
    font-weight: 600;
    color: #4a6a85;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: 14px;
  }

  /* Results */
  #results { max-width: 620px; margin: 0 auto; display: none; }

  .result-header {
    background: #1a2533;
    color: #fff;
    border-radius: 12px 12px 0 0;
    padding: 16px 22px;
    font-size: 15px;
    font-weight: 600;
  }

  .result-header .sport-tag {
    font-size: 12px;
    background: #3b8fd4;
    color: #fff;
    border-radius: 20px;
    padding: 2px 10px;
    margin-left: 8px;
    font-weight: 600;
    vertical-align: middle;
  }

  .result-card {
    background: #fff;
    border-left: 4px solid #3b8fd4;
    margin-bottom: 10px;
    padding: 16px 20px;
    border-radius: 0 8px 8px 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    box-shadow: 0 1px 6px rgba(30,90,150,0.06);
  }

  .result-card:last-child { border-radius: 0 8px 12px 0; }

  .result-city {
    font-size: 15px;
    font-weight: 700;
    color: #1a2533;
  }

  .result-time {
    font-size: 22px;
    font-weight: 700;
    color: #3b8fd4;
  }

  .result-date {
    font-size: 12px;
    color: #7a9ab5;
    margin-top: 2px;
  }

  .result-day-note {
    font-size: 11px;
    background: #e8f4fd;
    color: #2d7abf;
    border-radius: 20px;
    padding: 2px 9px;
    font-weight: 600;
  }

  .error-msg {
    color: #e05555;
    font-size: 13px;
    margin-top: 6px;
    display: none;
  }

  .divider { height: 1px; background: #e4eff7; margin: 18px 0; }

  @media (max-width: 500px) {
    .row-2 { grid-template-columns: 1fr; }
    h1 { font-size: 22px; }
    .result-time { font-size: 18px; }
  }
</style>
</head>
<body>

<h1>Sports Match Time Converter</h1>
<p class="subtitle">Convert any match kickoff or game time to local times worldwide</p>

<div class="card">
  <div class="section-title">Match Details</div>

  <div class="field-group">
    <label class="field-label">Sport / League</label>
    <select id="sport">
      <option value="">Select sport or league...</option>
      <option>Premier League (Football)</option>
      <option>UEFA Champions League</option>
      <option>La Liga</option>
      <option>Serie A</option>
      <option>Bundesliga</option>
      <option>FIFA World Cup</option>
      <option>IPL (Cricket)</option>
      <option>Test Cricket</option>
      <option>Formula 1</option>
      <option>NBA (Basketball)</option>
      <option>NFL (American Football)</option>
      <option>Wimbledon / Tennis</option>
      <option>Rugby World Cup</option>
      <option>Other</option>
    </select>
  </div>

  <div class="field-group">
    <label class="field-label">Match / Event Name <span style="font-weight:400;color:#90afc5">(optional)</span></label>
    <input type="text" id="matchName" placeholder="e.g. Man United vs Arsenal">
  </div>

  <div class="divider"></div>
  <div class="section-title">Broadcast / Kickoff Time</div>

  <div class="field-group">
    <label class="field-label">Match City / Broadcast Timezone</label>
    <input type="text" id="fromCity" placeholder="e.g. London, Mumbai, New York...">
    <div class="error-msg" id="fromError">City not recognised. Try a major city name.</div>
  </div>

  <div class="row-2">
    <div class="field-group">
      <label class="field-label">Date</label>
      <input type="date" id="matchDate">
    </div>
    <div class="field-group">
      <label class="field-label">Kickoff Time</label>
      <input type="time" id="matchTime">
    </div>
  </div>

  <div class="divider"></div>
  <div class="section-title">Convert To</div>

  <div id="toCities">
    <div class="city-row">
      <input type="text" placeholder="Your city (e.g. Sydney, Dubai, Toronto...)">
    </div>
  </div>

  <button class="btn btn-secondary" onclick="addCity()" style="margin-bottom:20px">+ ADD ANOTHER CITY</button>

  <button class="btn btn-primary" onclick="convertTimes()">CONVERT</button>
</div>

<!-- Results -->
<div id="results">
  <div class="result-header" id="resultHeader">Results</div>
  <div id="resultList"></div>
</div>

<script>
const { DateTime, IANAZone } = luxon;

const cityZones = {
  "london": "Europe/London",
  "manchester": "Europe/London",
  "birmingham": "Europe/London",
  "edinburgh": "Europe/London",
  "glasgow": "Europe/London",
  "dublin": "Europe/Dublin",
  "paris": "Europe/Paris",
  "berlin": "Europe/Berlin",
  "munich": "Europe/Berlin",
  "madrid": "Europe/Madrid",
  "barcelona": "Europe/Madrid",
  "rome": "Europe/Rome",
  "milan": "Europe/Rome",
  "amsterdam": "Europe/Amsterdam",
  "brussels": "Europe/Brussels",
  "zurich": "Europe/Zurich",
  "vienna": "Europe/Vienna",
  "stockholm": "Europe/Stockholm",
  "oslo": "Europe/Oslo",
  "copenhagen": "Europe/Copenhagen",
  "helsinki": "Europe/Helsinki",
  "warsaw": "Europe/Warsaw",
  "prague": "Europe/Prague",
  "budapest": "Europe/Budapest",
  "athens": "Europe/Athens",
  "istanbul": "Europe/Istanbul",
  "moscow": "Europe/Moscow",
  "dubai": "Asia/Dubai",
  "abu dhabi": "Asia/Dubai",
  "riyadh": "Asia/Riyadh",
  "doha": "Asia/Qatar",
  "kuwait": "Asia/Kuwait",
  "cairo": "Africa/Cairo",
  "nairobi": "Africa/Nairobi",
  "lagos": "Africa/Lagos",
  "johannesburg": "Africa/Johannesburg",
  "cape town": "Africa/Johannesburg",
  "mumbai": "Asia/Kolkata",
  "delhi": "Asia/Kolkata",
  "new delhi": "Asia/Kolkata",
  "bangalore": "Asia/Kolkata",
  "kolkata": "Asia/Kolkata",
  "chennai": "Asia/Kolkata",
  "hyderabad": "Asia/Kolkata",
  "ahmedabad": "Asia/Kolkata",
  "pune": "Asia/Kolkata",
  "karachi": "Asia/Karachi",
  "islamabad": "Asia/Karachi",
  "lahore": "Asia/Karachi",
  "dhaka": "Asia/Dhaka",
  "colombo": "Asia/Colombo",
  "kathmandu": "Asia/Kathmandu",
  "kabul": "Asia/Kabul",
  "tehran": "Asia/Tehran",
  "tashkent": "Asia/Tashkent",
  "almaty": "Asia/Almaty",
  "bangkok": "Asia/Bangkok",
  "jakarta": "Asia/Jakarta",
  "ho chi minh": "Asia/Ho_Chi_Minh",
  "hanoi": "Asia/Bangkok",
  "kuala lumpur": "Asia/Kuala_Lumpur",
  "singapore": "Asia/Singapore",
  "manila": "Asia/Manila",
  "hong kong": "Asia/Hong_Kong",
  "taipei": "Asia/Taipei",
  "beijing": "Asia/Shanghai",
  "shanghai": "Asia/Shanghai",
  "chengdu": "Asia/Shanghai",
  "guangzhou": "Asia/Shanghai",
  "shenzhen": "Asia/Shanghai",
  "seoul": "Asia/Seoul",
  "busan": "Asia/Seoul",
  "tokyo": "Asia/Tokyo",
  "osaka": "Asia/Tokyo",
  "sydney": "Australia/Sydney",
  "melbourne": "Australia/Melbourne",
  "brisbane": "Australia/Brisbane",
  "perth": "Australia/Perth",
  "adelaide": "Australia/Adelaide",
  "auckland": "Pacific/Auckland",
  "wellington": "Pacific/Auckland",
  "new york": "America/New_York",
  "nyc": "America/New_York",
  "boston": "America/New_York",
  "washington": "America/New_York",
  "miami": "America/New_York",
  "atlanta": "America/New_York",
  "toronto": "America/Toronto",
  "montreal": "America/Toronto",
  "chicago": "America/Chicago",
  "houston": "America/Chicago",
  "dallas": "America/Chicago",
  "denver": "America/Denver",
  "phoenix": "America/Phoenix",
  "los angeles": "America/Los_Angeles",
  "san francisco": "America/Los_Angeles",
  "seattle": "America/Los_Angeles",
  "las vegas": "America/Los_Angeles",
  "vancouver": "America/Vancouver",
  "calgary": "America/Edmonton",
  "mexico city": "America/Mexico_City",
  "sao paulo": "America/Sao_Paulo",
  "rio de janeiro": "America/Sao_Paulo",
  "buenos aires": "America/Argentina/Buenos_Aires",
  "bogota": "America/Bogota",
  "lima": "America/Lima",
  "santiago": "America/Santiago",
  "caracas": "America/Caracas",
  "accra": "Africa/Accra",
  "casablanca": "Africa/Casablanca",
  "addis ababa": "Africa/Addis_Ababa",
  "dar es salaam": "Africa/Dar_es_Salaam",
  "kampala": "Africa/Kampala",
  "lusaka": "Africa/Lusaka",
  "harare": "Africa/Harare",
};

function getZone(city) {
  const key = city.trim().toLowerCase();
  return cityZones[key] || null;
}

function addCity() {
  const container = document.getElementById('toCities');
  if (container.children.length >= 5) return;
  const row = document.createElement('div');
  row.className = 'city-row';
  row.innerHTML = `<input type="text" placeholder="Your city (e.g. Sydney, Dubai, Toronto...)">
    <button class="btn-remove" onclick="this.parentElement.remove()" title="Remove">&times;</button>`;
  container.appendChild(row);
}

function convertTimes() {
  const fromCityVal = document.getElementById('fromCity').value.trim();
  const dateVal = document.getElementById('matchDate').value;
  const timeVal = document.getElementById('matchTime').value;
  const sport = document.getElementById('sport').value;
  const matchName = document.getElementById('matchName').value.trim();
  const fromErr = document.getElementById('fromError');

  fromErr.style.display = 'none';

  if (!fromCityVal || !dateVal || !timeVal) {
    alert('Please fill in the match city, date, and kickoff time.');
    return;
  }

  const fromZone = getZone(fromCityVal);
  if (!fromZone) {
    fromErr.style.display = 'block';
    return;
  }

  const [h, m] = timeVal.split(':');
  const [y, mo, d] = dateVal.split('-');
  const matchDT = DateTime.fromObject(
    { year: +y, month: +mo, day: +d, hour: +h, minute: +m },
    { zone: fromZone }
  );

  const cityInputs = document.querySelectorAll('#toCities input');
  const toCities = Array.from(cityInputs).map(i => i.value.trim()).filter(Boolean);

  if (toCities.length === 0) {
    alert('Please add at least one city to convert to.');
    return;
  }

  const resultsDiv = document.getElementById('results');
  const resultList = document.getElementById('resultList');
  const resultHeader = document.getElementById('resultHeader');

  const sportTag = sport ? `<span class="sport-tag">${sport}</span>` : '';
  const matchLabel = matchName || 'Match';
  resultHeader.innerHTML = `${matchLabel} ${sportTag}<br><span style="font-size:12px;font-weight:400;color:#90afc5;">Kickoff: ${matchDT.toFormat('dd MMM yyyy, HH:mm')} (${fromCityVal})</span>`;

  resultList.innerHTML = '';

  const sourceDayNum = matchDT.day;

  toCities.forEach(city => {
    const zone = getZone(city);
    const row = document.createElement('div');
    row.className = 'result-card';

    if (!zone) {
      row.innerHTML = `<div><div class="result-city">${city}</div><div class="result-date" style="color:#e05555">City not recognised</div></div>`;
    } else {
      const converted = matchDT.setZone(zone);
      const dayDiff = converted.day - sourceDayNum;
      let dayNote = '';
      if (dayDiff === 1 || dayDiff === -6) dayNote = `<span class="result-day-note">Next day</span>`;
      else if (dayDiff === -1 || dayDiff === 6) dayNote = `<span class="result-day-note">Previous day</span>`;

      row.innerHTML = `
        <div>
          <div class="result-city">${city}</div>
          <div class="result-date">${converted.toFormat('cccc, dd MMM yyyy')}</div>
        </div>
        <div style="text-align:right">
          <div class="result-time">${converted.toFormat('HH:mm')}</div>
          <div class="result-date">${converted.toFormat('a').toLowerCase()} &middot; ${converted.offsetNameShort}</div>
        </div>
        ${dayNote}
      `;
    }
    resultList.appendChild(row);
  });

  resultsDiv.style.display = 'block';
  resultsDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// Set today's date as default
document.getElementById('matchDate').value = new Date().toISOString().split('T')[0];
</script>
</body>
</html>
